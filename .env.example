# Local Docker Compose: use the same URL for DATABASE_URL and DIRECT_URL.
# Production (Neon): set DATABASE_URL and DIRECT_URL to the non-pooled (direct)
# connection string with ?connection_limit=5. Skip the PgBouncer pooler so
# Prisma interactive $transaction works on a long-lived Nest process.

DATABASE_URL=postgresql://posbuzz:posbuzz@localhost:5432/posbuzz?schema=public
DIRECT_URL=postgresql://posbuzz:posbuzz@localhost:5432/posbuzz?schema=public

# Local: redis://localhost:6379
# Upstash: copy the Redis URL from the console (must start with rediss://)
# Do NOT use the REST API URL here.
REDIS_URL=redis://localhost:6379

# Min 32 characters in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Comma-separated allowed browser origins (local Vite + Cloudflare Pages)
WEB_ORIGIN=http://localhost:5173

# true for local/dev only; false in production (seed creates demo user)
AUTH_ALLOW_REGISTER=true

PORT=3000

# Overrides seed password for demo@posbuzz.dev (default documented in README)
SEED_DEMO_PASSWORD=DemoPass123!

# Frontend (apps/web) — Vite
VITE_API_URL=http://localhost:3000
